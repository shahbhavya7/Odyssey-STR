# ===========================================================================
# Escalio — Docker environment template
#
#   cp .env.docker.example .env      then edit the values you need.
#
# Everything has a sensible default, so the ONLY thing most people change is
# one LLM key (or nothing at all — leave it blank to run in mock mode).
# ===========================================================================

# --- LLM provider ----------------------------------------------------------
# "groq" (default, hosted) | "openai" (hosted) | "ollama" (local, set via overlay)
PROVIDER=groq

# Groq (default hosted provider). Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

# OpenAI (only used when PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (only used with the ollama overlay). Smaller = lighter for edge/laptops.
#   qwen2.5:7b (default) · qwen2.5:3b · qwen2.5:1.5b
OLLAMA_MODEL=qwen2.5:7b

# Force the offline keyword mock even if a key is present (handy for demos/CI).
MOCK_MODE=false

# --- Database (defaults match the bundled Postgres service) -----------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ticketrouter

# --- Image source ----------------------------------------------------------
# Leave blank to BUILD locally from the Dockerfile.
# To PULL the prebuilt multi-arch image instead (fast, no build — great for
# edge devices), set it to the published image, e.g.:
#   ESCALIO_IMAGE=ghcr.io/your-username/escalio:latest
ESCALIO_IMAGE=
