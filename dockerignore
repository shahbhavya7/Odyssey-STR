__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Editor / OS
.idea/
.vscode/
.DS_Store

# Docs and local scratch (not needed at runtime)
*.md
!README.md
docs/
notebooks/
tests/
