# --- OpenAI ---
# Your OpenAI API key. Never commit the real .env file.
OPENAI_API_KEY=sk-your-key-here

# Which model to use for ticket routing.
MODEL=gpt-4o-mini

# 0 = deterministic output (same input -> same answer). Keep at 0 for routing.
TEMPERATURE=0

# How many times to retry the model call if it fails or returns bad JSON.
MAX_RETRIES=2

# --- App behavior ---
# true = run with no API key (uses a built-in mock router; added in Phase 1).
MOCK_MODE=false

# Tickets longer than this are truncated before being sent to the model.
MAX_INPUT_CHARS=6000

# --- Database ---
# Connection string for the local PostgreSQL database.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ticketrouter
