# --- Provider switch: "ollama" during development, "openai" for final/demo ---
PROVIDER=ollama

# --- Ollama (local, free) ---
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- OpenAI (used only when PROVIDER=openai) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Shared model behaviour ---
TEMPERATURE=0
MAX_RETRIES=2
MOCK_MODE=false            # true = run with no model at all (offline stub)
MAX_INPUT_CHARS=6000

# --- Database (local Postgres) ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ticketrouter

# API base URL for the Streamlit UI
API_BASE_URL=http://localhost:8000
