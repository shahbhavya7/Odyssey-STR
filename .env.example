# --- Provider switch: "groq" (default) · "ollama" (local) · "openai" ---
PROVIDER=groq

# --- Default provider — fast hosted Qwen inference via Groq, no local server needed ---
GROQ_API_KEY=gsk-your-key-here
GROQ_MODEL=qwen/qwen3-32b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Alternative: local Ollama (free, offline, but slower — set PROVIDER=ollama to use) ---
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Optional: OpenAI (used only when PROVIDER=openai) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Shared model behaviour ---
TEMPERATURE=0
MAX_RETRIES=2
MOCK_MODE=false            # true = run with no model at all (offline stub)
MAX_INPUT_CHARS=6000

# --- Database: local Postgres (default) ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ticketrouter
# --- OR Neon serverless Postgres (hosted; works from a fresh clone) ---
# Neon uses a "-pooler" host and requires SSL in the URL. Example shape only:
#DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ENDPOINT-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require

# API base URL for the Streamlit UI
API_BASE_URL=http://localhost:8000
